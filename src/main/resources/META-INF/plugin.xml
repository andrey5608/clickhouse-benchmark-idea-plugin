<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.andrey5608.clickhouse.benchmark.idea.plugin</id>
    <name>ClickHouse Benchmark</name>
    <vendor>andrey5608</vendor>

    <depends>com.intellij.modules.platform</depends>

    <!--
        com.intellij.database is OPTIONAL.
        When present (IDEA Ultimate): DataSource picker lets user pick existing ClickHouse connections.
        When absent (IDEA Community): plugin falls back to connection settings configured in Tools > ClickHouse Benchmark.
        All code that imports com.intellij.database.* lives exclusively in clickhouse-benchmark-database.xml
        and DatabasePluginDataSourceProvider — those classes are never loaded on Community.
    -->
    <depends optional="true" config-file="clickhouse-benchmark-database.xml">com.intellij.database</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">

        <toolWindow
            id="ClickHouse Benchmark"
            factoryClass="com.github.andrey5608.clickhouse.benchmark.idea.plugin.toolWindow.BenchmarkToolWindowFactory"
            anchor="bottom"
            icon="AllIcons.Debugger.Console"/>

        <!-- HTTP benchmark engine + persisted settings (host/port/iterations/warmup) -->
        <applicationService
            serviceImplementation="com.github.andrey5608.clickhouse.benchmark.idea.plugin.services.BenchmarkRunner"/>

        <projectService
            serviceImplementation="com.github.andrey5608.clickhouse.benchmark.idea.plugin.services.BenchmarkHistoryService"/>

        <!--
            DataSourceProvider default impl — returns empty list (Community edition / no DB plugin).
            Overridden in clickhouse-benchmark-database.xml when com.intellij.database is present.
        -->
        <applicationService
            serviceInterface="com.github.andrey5608.clickhouse.benchmark.idea.plugin.services.DataSourceProvider"
            serviceImplementation="com.github.andrey5608.clickhouse.benchmark.idea.plugin.services.DefaultDataSourceProvider"/>

        <applicationConfigurable
            parentId="tools"
            id="com.github.andrey5608.clickhouse.benchmark.idea.plugin.settings.BenchmarkSettingsConfigurable"
            displayName="ClickHouse Benchmark"
            instance="com.github.andrey5608.clickhouse.benchmark.idea.plugin.settings.BenchmarkSettingsConfigurable"/>

    </extensions>

    <actions>
        <action
            id="ClickHouseBenchmark.Run"
            class="com.github.andrey5608.clickhouse.benchmark.idea.plugin.actions.RunBenchmarkAction"
            text="Run as ClickHouse Benchmark"
            description="Execute selected SQL via clickhouse-client and record server-side metrics"
            icon="AllIcons.Actions.Execute">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift B"/>
        </action>
    </actions>

</idea-plugin>
